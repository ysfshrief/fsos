rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userDoc().role == 'admin' && userDoc().approved == true;
    }

    function isApprovedRole(r) {
      return isSignedIn() && userDoc().role == r && userDoc().approved == true;
    }

    // ---------- USERS ----------
    match /users/{uid} {
      // Anyone signed in can create their own profile (pending approval)
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.approved == false
                    && request.resource.data.role in ['student', 'parent', 'teacher'];
      // Read own profile; admins read all; teachers read students
      allow read: if isSignedIn() && (
        request.auth.uid == uid || isAdmin() || isApprovedRole('teacher')
      );
      // Only admin can update (approval, role, classId, childrenIds)
      allow update, delete: if isAdmin();
    }

    // ---------- GRADES ----------
    match /grades/{gradeId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid ||
        isAdmin() || isApprovedRole('teacher') ||
        (isApprovedRole('parent') && resource.data.studentId in userDoc().childrenIds)
      );
      allow write: if isAdmin() || isApprovedRole('teacher');
    }

    // ---------- HOMEWORK ----------
    match /homework/{hwId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isApprovedRole('teacher');
    }

    // ---------- ATTENDANCE ----------
    match /attendance/{attId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isApprovedRole('teacher');
    }

    // ---------- NEWS (public site reads) ----------
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CLASSES ----------
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- CMS: SITE SETTINGS (public site reads) ----------
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: SECTIONS (public site reads) ----------
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: BANNERS (public site reads) ----------
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: ACHIEVERS / Hall of Fame (public reads) ----------
    match /achievers/{achieverId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: COURSES (public reads) ----------
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: STAFF (public reads) ----------
    match /staff/{staffId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: FACILITIES (public reads) ----------
    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: ACTIVITIES (public reads) ----------
    match /activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- CMS: PARTNERS (public reads) ----------
    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- JOB APPLICATIONS (public submit, admin manages) ----------
    match /applications/{appId} {
      allow create: if true;               // anyone can apply
      allow read, update, delete: if isAdmin();
    }

    // ---------- SPECIALIST MESSAGES (confidential: public submit, admin reads) ----------
    match /specialist_messages/{msgId} {
      allow create: if true;               // anyone can send
      allow read, update, delete: if isAdmin();
    }
  }
}
